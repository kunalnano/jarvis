# Yennefer Environment Variables
# Copy this file to .env and fill in your values
# Get your ElevenLabs API key at: https://elevenlabs.io/app/settings/api-keys

ELEVENLABS_API_KEY=your_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# Optional: local-first LM Studio routing.
# Prometheus is primary; Stormbreaker/Windows is fallback.
# LM_STUDIO_API_BASE=http://localhost:1234/v1
# LM_API_TOKEN=your_prometheus_lm_studio_token_here
# STORMBREAKER_LM_STUDIO_API_BASE=http://192.168.4.48:1234/v1
# STORMBREAKER_LM_STUDIO_API_KEY=your_stormbreaker_lm_studio_token_here
# WINDOWS_LM_STUDIO_API_BASE=http://192.168.4.48:1234/v1
# WINDOWS_LM_STUDIO_API_KEY=your_windows_lm_studio_token_here

# Optional: stronger live web search providers.
# Without these, Yennefer falls back to Bing RSS for personal daily searches.
# SERPER_API_KEY=your_serper_key_here
# GOOGLE_API_KEY=your_google_api_key_here
# GOOGLE_SEARCH_ENGINE_ID=your_programmable_search_engine_id_here
# BRAVE_API_KEY=your_brave_search_key_here
