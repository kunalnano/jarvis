# Yennefer Environment Variables
# Copy this file to .env and fill in your values
# Get your ElevenLabs API key at: https://elevenlabs.io/app/settings/api-keys

ELEVENLABS_API_KEY=your_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# Optional: Override LM Studio endpoint
# LM_STUDIO_API_BASE=http://localhost:1234/v1

# Optional: local Linear bridge. The bridge process holds LINEAR_API_KEY;
# Yennefer only receives this narrow loopback URL and bearer token.
# YENNEFER_LINEAR_BRIDGE_URL=http://127.0.0.1:4351
# YENNEFER_LINEAR_BRIDGE_TOKEN=replace_with_local_bridge_token
# YENNEFER_LINEAR_AUDIT_LOG=~/.yennefer/linear-bridge-audit.jsonl
